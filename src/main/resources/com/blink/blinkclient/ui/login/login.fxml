<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.blink.blinkclient.ui.LoginController"
      stylesheets="@login.css"
      styleClass="login-container"
      alignment="CENTER"
      spacing="15.0">

    <padding>
        <Insets top="40" right="40" bottom="40" left="40"/>
    </padding>

    <Label text="Blink" styleClass="title-label"/>

    <TextField fx:id="usernameField" promptText="Username" styleClass="input-field"/>

    <PasswordField fx:id="passwordField" promptText="Password" styleClass="input-field"/>

    <Button fx:id="loginButton" text="Sign In" onAction="#handleLogin" styleClass="submit-button"/>

    <Label fx:id="errorLabel" styleClass="error-message"/>
</VBox>