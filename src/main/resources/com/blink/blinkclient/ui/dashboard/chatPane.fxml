<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.blink.blinkclient.ui.ChatPaneController"
            style="-fx-background-color: #2f3136;">

    <top>
        <HBox style="-fx-background-color: #36393f; -fx-border-color: #202225; -fx-border-width: 0 0 1px 0;" alignment="CENTER_LEFT" prefHeight="50">
            <padding><Insets left="20"/></padding>
            <Label fx:id="chatTitleLabel" text="# general-chat" style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;"/>
        </HBox>
    </top>

    <center>
        <ListView fx:id="messageListView" style="-fx-background-color: transparent; -fx-background-insets: 0; -fx-padding: 10;" VBox.vgrow="ALWAYS"/>
    </center>

    <bottom>
        <HBox spacing="10" alignment="CENTER">
            <padding><Insets top="10" right="20" bottom="20" left="20"/></padding>
            <TextField fx:id="messageInputField" promptText="Message..." HBox.hgrow="ALWAYS"
                       style="-fx-background-color: #40444b; -fx-text-fill: white; -fx-prompt-text-fill: #72767d; -fx-background-radius: 8; -fx-padding: 10;"
                       onAction="#handleSendMessage"/>
            <Button text="Send" onAction="#handleSendMessage"
                    style="-fx-background-color: #5b62f4; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 10 20 10 20; -fx-cursor: hand;"/>
        </HBox>
    </bottom>
</BorderPane>